<UserControl x:Class="FindText.UC.UCSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:app="clr-namespace:FindText"
             xmlns:local="clr-namespace:FindText.UC"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="300">

    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush2}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </UserControl.Resources>

    <Grid x:Name="DivRoot" Background="{DynamicResource BackgroundBrush2}" DataContext="{x:Static app:TextCache.Text}"  >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <Border Grid.ColumnSpan="3" Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="8" CornerRadius="5" >
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="0"/>
                    <RowDefinition Height="48"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="80*" />
                    <ColumnDefinition Width="32" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="🏴：" HorizontalAlignment="Right" Grid.Row="0" FontSize="18"  />
                <ComboBox x:Name="comboboxLanguage" Height="28" Grid.Row="0" BorderThickness="0,0,0,1" SelectedIndex="-1"  Grid.Column="1" Visibility="Collapsed" 
                          Background="{DynamicResource BackgroundBrush2}" IsEditable="False" >
                    <ComboBox.Items>
                        <TextBlock Text = "    🗁" Tag="Ext" FontSize="18" Height="32" HorizontalAlignment="Center" VerticalAlignment="Center"  TextAlignment="Center"/>
                    </ComboBox.Items>
                </ComboBox>

                <TextBlock Text="🎨：" HorizontalAlignment="Right" Grid.Row="1" FontSize="18" />
                <ComboBox x:Name="comboboxTheme" Height="28" Grid.Row="1" BorderThickness="0,0,0,1" SelectedIndex="0" 
                          Grid.Column="1" Background="{DynamicResource BackgroundBrush2}" DisplayMemberPath="Value" />


            </Grid>
        </Border>

        <Border Grid.ColumnSpan="3" Height="116" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="8" Grid.Row="1" CornerRadius="5" >
            <Grid >
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="90*"/>
                    <ColumnDefinition Width="8"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="dddd" Text="{Binding [Tool.UnixTitle]}" Grid.ColumnSpan="2" FontSize="14" Foreground="{DynamicResource ForegroundBrush2}"/>


                <TextBlock Text="{Binding [Tool.UnixLabel]}" Grid.Row="1" HorizontalAlignment="Right" />

                <TextBox x:Name="inputUnixTime" Grid.Column="1" Grid.Row="1" Height="26" MaxLength="13" />

                <TextBlock Text="{Binding [Tool.DateLabel]}" Grid.Row="2" HorizontalAlignment="Right" />

                <TextBox x:Name="inputDatetime" Grid.Column="1" Grid.Row="2" Height="26"  />

            </Grid>
        </Border>

        <Border Grid.ColumnSpan="3" Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="8" CornerRadius="5" >
            <Grid Margin="12" >
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                </Grid.RowDefinitions>

                <Button x:Name="buttonOpenLocal" Content="{Binding [Tool.CacheDir]}" BorderBrush="{DynamicResource BorderBrush}" Grid.Row="0" Width="120" BorderThickness="0,0,0,1" Background="Transparent"  />

                <Button x:Name="buttonToolsWnd" Content="{Binding [Tool.ToolsWnd]}" Visibility="Collapsed" BorderBrush="{DynamicResource BorderBrush}" Grid.Row="1" Width="120" BorderThickness="0,0,0,1" Background="Transparent"  />
            </Grid>

        </Border>

    </Grid>

</UserControl>
