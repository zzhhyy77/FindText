<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="Color_Error">#FFFF2E12</Color>
    <Color x:Key="Color_Red">#FFBD404D</Color>
    <Color x:Key="Color_Green">#FF199900</Color>
    <Color x:Key="Color_Blue">#FF51B4FF</Color>
    <Color x:Key="Color_Transparent">#00000000</Color>

    <!--逐渐过度的系列颜色-->
    <Color x:Key="Color_01">#FF101010</Color>
    <Color x:Key="Color_02">#FF303030</Color>
    <Color x:Key="Color_03">#FF505050</Color>
    <Color x:Key="Color_04">#FF707070</Color>
    <Color x:Key="Color_05">#FF909090</Color>
    <Color x:Key="Color_06">#FFB0B0B0</Color>
    <Color x:Key="Color_07">#FFD0D0D0</Color>
    <Color x:Key="Color_08">#FFF0F0F0</Color>

    <!--用户可操作的控件前景色，按钮、输入框等-->
    <Color x:Key="Color_UI">#FF016AA1</Color>
    <Color x:Key="Color_UI2">#FF001EA0</Color>

    
    <Color x:Key="Color_Foreground">#FF1F1F1F</Color>
    <Color x:Key="Color_Background">#FFF1F1F1</Color>

    <!-- 需要和主背景区分开的前景和背景 -->
    <Color x:Key="Color_Foreground2">#FF3E3E3E</Color>
    <Color x:Key="Color_Background2">#FFC0C0C0</Color>

    <Color x:Key="Color_Border">#FF4E4E4E</Color>
    <Color x:Key="Color_HoverBorder">#50006CBE</Color>
    <Color x:Key="Color_Hover">#50006CBE</Color>
    <Color x:Key="Color_Pressed">#70006CBE</Color>
    <Color x:Key="Color_Selection">#90006CBE</Color>
    <Color x:Key="Color_Disabled">#FFA0A0A0</Color>
    
    <!--<SolidColorBrush x:Key="BrushLightTemp" Color="#FF006CBE"  />-->

</ResourceDictionary>