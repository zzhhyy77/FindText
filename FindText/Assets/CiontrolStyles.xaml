                        </ContentControl>
                        <Rectangle x:Name="FocusedVisualElement" Stroke="{StaticResource BorderBrush}" Visibility="Collapsed" StrokeThickness="0,0,0,0"/>
                        <Rectangle x:Name="DisabledVisualElement" Fill="{StaticResource DisabledBrush}" Visibility="Collapsed" Opacity="0.5" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

